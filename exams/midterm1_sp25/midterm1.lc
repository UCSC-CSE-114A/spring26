eval problem_3 : 
  TRUE TRUE TRUE =~> TRUE
  --TRUE TRUE =~> TRUE
  --ITE TRUE FALSE =~> TRUE
  --ITE TRUE FALSE TRUE =~> TRUE
  --FALSE TRUE FALSE =~> TRUE

-- Problem 4
eval problem_4 :
  --ITE TRUE ONE =~> ONE
  --FST (PAIR (PAIR ONE ZERO) (PAIR ONE ZERO)) =~> ONE
  --ONE ZERO =~> ONE
  --TRUE ZERO ONE =~> ONE
  TRUE ONE ZERO =~> ONE

eval problem_5 :
  (\q r -> r) y (\x y -> x (q r y)) =~> \x y -> x (q r y)

-- Problem 6
eval pairzero_test_1 :
  PAIRZERO (PAIR ZERO ZERO) =~> TRUE

eval pairzero_test_2 :
  PAIRZERO (PAIR ONE ZERO) =~> FALSE

eval pairzero_test_3 :
  PAIRZERO (PAIR ZERO ONE) =~> FALSE

eval pairzero_test_4 :
  PAIRZERO (PAIR TWO THREE) =~> FALSE

eval pairzero_test_5 :
  PAIRZERO (PAIR (DECR ONE) (DECR (DECR TWO))) =~> TRUE
  
-- Problem 7
eval first2true_test_1 :
  FIRST2TRUE (CONS TRUE (CONS TRUE NIL))
  =~> TRUE

eval first2true_test_2 :
  FIRST2TRUE (CONS TRUE (CONS FALSE NIL))
  =~> FALSE

eval first2true_test_3 :
  FIRST2TRUE (CONS FALSE (CONS TRUE NIL))
  =~> FALSE
eval first2true_test_4 :
  FIRST2TRUE (CONS TRUE (CONS TRUE (CONS FALSE NIL)))
  =~> TRUE

eval first2true_test_5 :
  FIRST2TRUE (CONS TRUE (CONS TRUE (CONS TRUE NIL)))
  =~> TRUE

eval first2true_test_6 :
  FIRST2TRUE (CONS TRUE (CONS FALSE (CONS TRUE NIL)))
  =~> FALSE

-- Problem 8
eval isnil_test_1 :
  ISNIL NIL
  =~> TRUE

eval isnil_test_2 :
  ISNIL (CONS ONE NIL)
  =~> FALSE

eval isnil_test_3 :
  ISNIL (CONS TWO (CONS ONE NIL))
  =~> FALSE

eval isnil_test_4 :
  ISNIL (CONS ONE (CONS TWO (CONS THREE NIL)))
  =~> FALSE

eval andlist_test_1 :
  ANDLIST NIL
  =~> TRUE

eval andlist_test_2 :
  ANDLIST (CONS TRUE NIL)
  =~> TRUE

eval andlist_test_3 :
  ANDLIST (CONS FALSE NIL)
  =~> FALSE

eval andlist_test_4 :
  ANDLIST (CONS TRUE (CONS FALSE (CONS TRUE NIL)))
  =~> FALSE

eval andlist_test_5 :
  ANDLIST (CONS TRUE (CONS TRUE (CONS FALSE NIL)))
  =~> FALSE

eval andlist_test_6 :
  ANDLIST (CONS TRUE (CONS TRUE (CONS TRUE NIL)))
  =~> TRUE
