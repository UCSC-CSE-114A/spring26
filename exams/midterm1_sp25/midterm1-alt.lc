  --ITE FALSE FALSE TRUE =~> FALSE
  FALSE TRUE FALSE =~> FALSE

-- Problem 4
eval problem_4 :
  SND (PAIR (PAIR ONE ZERO) ZERO) =~> ZERO
  --TRUE ZERO =~> ZERO
  --TRUE ONE ZERO =~> ZERO
  --FALSE ZERO ONE =~> ZERO
  --FALSE ZERO =~> ZERO

-- Problem 5
eval problem_5 :
  (\x y -> y) z (\y -> x z y) =~> \y -> x z y

-- Problem 6
eval problem6_test_1 :
  PAIRSUMINCR (PAIR ZERO ZERO) =~> ONE

eval problem6_test_2 :
  PAIRSUMINCR (PAIR ONE ZERO) =~> TWO

eval problem6_test_3 :
  PAIRSUMINCR (PAIR TWO ZERO) =~> THREE

eval problem6_test_4 :
  PAIRSUMINCR (PAIR ONE (DECR (DECR TWO))) =~> TWO
  
-- Problem 7
eval problem7_test_1 :
  INCRSECOND (CONS TWO (CONS TWO NIL)) =~> THREE

eval problem7_test_2 :
  INCRSECOND (CONS ZERO (CONS TWO NIL)) =~> THREE

eval problem7_test_3 :
  INCRSECOND (CONS ZERO (CONS ONE (CONS TWO NIL))) =~> TWO

eval problem7_test_4 :
  INCRSECOND (CONS ZERO (CONS ZERO (CONS THREE NIL))) =~> ONE

eval problem7_test_5 :
  INCRSECOND (CONS THREE (CONS ONE (CONS ZERO NIL))) =~> TWO

-- Problem 8
eval isnil_test_1 :
  ISNIL NIL
  =~> TRUE

eval isnil_test_2 :
  ISNIL (CONS ONE NIL)
  =~> FALSE

eval isnil_test_3 :
  ISNIL (CONS TWO (CONS ONE NIL))
  =~> FALSE

eval isnil_test_4 :
  ISNIL (CONS ONE (CONS TWO (CONS THREE NIL)))
  =~> FALSE

eval doubleall_test_1 :
  DOUBLEALL NIL =~> NIL

eval doubleall_test_2 :
  -- CONS TWO NIL
  DOUBLEALL (CONS ONE NIL) =~> \b -> b TWO NIL 

eval doubleall_test_3 :
  -- CONS TWO (CONS FOUR NIL)
  DOUBLEALL (CONS ONE (CONS TWO NIL)) =~> \b -> b TWO (\b -> b FOUR NIL)

eval doubleall_test_4 :
  -- CONS FOUR (CONS ZERO (CONS TWO NIL))
  DOUBLEALL (CONS TWO (CONS ZERO (CONS ONE NIL))) =~> \b -> b FOUR (\b -> b ZERO (\b -> b TWO NIL))